{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeharness.local/schemas/run-manifest.schema.json",
  "title": "VibeHarness Run Manifest",
  "type": "object",
  "required": ["schemaVersion", "runId", "workflow", "adapter", "status", "startedAt", "completedAt", "stages", "policyDecisions", "tests", "artifacts"],
  "properties": {
    "schemaVersion": { "const": "v1alpha1" },
    "runId": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "adapter": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "approval_required"] },
    "startedAt": { "type": "string", "minLength": 1 },
    "completedAt": { "type": "string", "minLength": 1 },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "artifacts"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pending", "running", "blocked", "failed", "passed", "skipped"] },
          "artifacts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "policyDecisions": {
      "type": "array",
      "items": { "$ref": "policy-decision.schema.json" }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "skipped"] }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
