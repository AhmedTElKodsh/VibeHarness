{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeharness.local/schemas/compiled-archon.schema.json",
  "title": "VibeHarness Compiled Archon Workflow",
  "type": "object",
  "required": ["schemaVersion", "target", "workflow", "nodes"],
  "properties": {
    "schemaVersion": { "const": "v1alpha1" },
    "target": { "const": "archon" },
    "workflow": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "required", "adapter", "ecc_profile", "outputs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "adapter": { "type": "string", "minLength": 1 },
          "ecc_profile": {
            "type": "object",
            "required": ["name", "memory_mode", "approved_skills", "pre_stage_hooks", "post_stage_hooks"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "memory_mode": { "enum": ["proposal_only", "disabled"] },
              "approved_skills": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "pre_stage_hooks": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "post_stage_hooks": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
