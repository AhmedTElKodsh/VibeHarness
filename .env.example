# VibeHarness Engine environment

# Optional: choose where local run artifacts and adapter state should live.
# Defaults are project-local `.vibeharness/` paths where applicable.
# VIBEHARNESS_HOME=~/.vibeharness

# Optional: OpenHands adapter endpoint for future real execution.
# The MVP uses the deterministic mock adapter and does not require this.
# OPENHANDS_BASE_URL=http://localhost:3000
# OPENHANDS_API_KEY=

# Optional: provider credentials for future adapter integrations.
# Keep secrets in environment variables or local secret stores, never in fixtures.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GITHUB_TOKEN=

# Optional: force deterministic timestamps in tests or scripted demos.
# VIBEHARNESS_FIXED_RUN_ID=20260614000000
